{
  "name": "sparks-ui",
  "version": "0.1.0",
  "description": "A React UI component library with theming and accessibility",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./button": {
      "import": "./dist/components/Button/Button.js",
      "require": "./dist/components/Button/Button.cjs"
    },
    "./icon": {
      "import": "./dist/components/Icon/Icon.js",
      "require": "./dist/components/Icon/Icon.cjs"
    },
    "./typography": {
      "import": "./dist/components/Typography/Text.js",
      "require": "./dist/components/Typography/Text.cjs"
    },
    "./input": {
      "import": "./dist/components/Input/Input.js",
      "require": "./dist/components/Input/Input.cjs"
    },
    "./card": {
      "import": "./dist/components/Card/Card.js",
      "require": "./dist/components/Card/Card.cjs"
    },
    "./container": {
      "import": "./dist/components/Container/Container.js",
      "require": "./dist/components/Container/Container.cjs"
    },
    "./theme": {
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./tokens": {
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json}\""
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@storybook/addon-docs": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-links": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-storybook": "^0.11.4",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.12",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2",
    "vite": "^5.4.2"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "react",
    "ui",
    "component-library",
    "design-system",
    "theming",
    "accessible"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sparks-ui/sparks-ui"
  }
}
